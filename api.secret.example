# Copy this file to api.secret and fill in your values.
# api.secret is gitignored and will never be committed.

# Required only if you use a cloud LLM instead of Ollama (optional).
# PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Recommended for network/LAN hosting — set this to a long random string.
# For local-only use, the default in app.py is fine.
# FLASK_SECRET_KEY=change-me-to-a-long-random-string
