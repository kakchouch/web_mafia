# ============================================================
# Configuration du jeu Loup-Garou
# Modifiez ce fichier pour personnaliser la partie.
# ============================================================

# --- Modèle IA (Ollama) ---
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CTX_SIZE=32768

# --- Serveur Flask ---
FLASK_PORT=5000
FLASK_DEBUG=True

# --- Joueurs ---
PLAYER_COUNT_MIN=4
PLAYER_COUNT_MAX=12
PLAYER_COUNT_DEFAULT=8

# --- IA : narration ---
AI_NARRATION_MAX_TOKENS=60
AI_NARRATION_TEMPERATURE=1.0

# --- IA : dialogue PNJ ---
AI_DIALOGUE_MAX_TOKENS=150
AI_DIALOGUE_TEMPERATURE=1.0

# --- IA : vote PNJ ---
AI_VOTE_MAX_TOKENS=15
AI_VOTE_TEMPERATURE=0.0

# --- IA : délibération des loups ---
AI_WOLF_MAX_TOKENS=80
AI_WOLF_TEMPERATURE=1.0

# --- Discussion (nombre de passes par tour de parole) ---
DISCUSSION_PASSES=1

# --- Timeouts (secondes) ---
TTS_ACK_TIMEOUT=45
HUMAN_CHAT_TIMEOUT_1=120
HUMAN_CHAT_TIMEOUT_2=90

# --- TTS Kokoro ---
TTS_NARRATOR_SPEED=1.3
